# =============================================================================
# .env.example — Plantilla de variables de entorno
# Copiar a .env y rellenar con valores reales. NUNCA commitear .env con secretos.
# Variables marcadas con [CRITICA] son requeridas en producción (APP_ENV=production).
# =============================================================================

# Entorno (production / development)
APP_ENV=development

# =============================================================================
# Base de datos PostgreSQL
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hrdb
POSTGRES_USER=hr_david
# [CRITICA] Usar un valor fuerte: openssl rand -base64 32
POSTGRES_PASSWORD=CAMBIAR_POR_VALOR_FUERTE
POSTGRES_CONNECT_TIMEOUT=5
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# =============================================================================
# Neo4j
# =============================================================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
# [CRITICA] Usar un valor fuerte: openssl rand -base64 32
NEO4J_PASSWORD=CAMBIAR_POR_VALOR_FUERTE

# =============================================================================
# Redis / Celery
# =============================================================================
CELERY_BROKER_URL=redis://chatwoot_redis:6379/1
CELERY_RESULT_BACKEND=redis://chatwoot_redis:6379/1

# =============================================================================
# Chatwoot
# =============================================================================
CHATWOOT_BASE_URL=https://tu-instancia-chatwoot.com
CHATWOOT_API_TOKEN=CAMBIAR_POR_TOKEN_REAL
# [CRITICA] Token para autenticar webhooks entrantes de Chatwoot.
# Generar con: openssl rand -hex 32
# Usar el mismo valor en la config del webhook de Chatwoot.
CHATWOOT_WEBHOOK_TOKEN=CAMBIAR_POR_TOKEN_FUERTE
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
CHATWOOT_RH_QUEUE_INBOX_ID=1
CHATWOOT_RH_QUEUE_ACCOUNT_ID=1

# =============================================================================
# Groq (LLM)
# =============================================================================
# [CRITICA] Obtener en console.groq.com
GROQ_API_KEY=CAMBIAR_POR_CLAVE_GROQ
GROQ_API_KEY_BACKUP=CAMBIAR_POR_CLAVE_GROQ_BACKUP
GROQ_MODEL=llama-3.3-70b-versatile
# Modelo de visión Groq para imágenes y stickers (multimodal)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# =============================================================================
# Seguridad — endpoints internos
# =============================================================================
# [CRITICA] Protege /ask, /orchestrate/message, /classify, /admin/*.
# Fail-closed: vacío = 401 siempre. Generar con: openssl rand -hex 32
INTERNAL_API_KEY=CAMBIAR_POR_CLAVE_FUERTE
# [CRITICA] Protege /reindex. Generar con: openssl rand -hex 32
REINDEX_API_KEY=CAMBIAR_POR_CLAVE_FUERTE

# =============================================================================
# ngrok (solo desarrollo/demo — reemplazar con IP fija + TLS en producción)
# =============================================================================
NGROK_AUTHTOKEN=CAMBIAR_POR_TOKEN_NGROK

# =============================================================================
# Telegram (si se usa)
# =============================================================================
TELEGRAM_BOT_TOKEN=CAMBIAR_POR_TOKEN_TELEGRAM

# =============================================================================
# RAG / Chroma / Embeddings
# =============================================================================
EMBEDDING_MODEL=BAAI/bge-m3
DATA_DIR=/app/data
DB_DIR=/app/chroma_db_bge_m3
CHROMA_DB_DIR=/app/chroma_db_bge_m3
COLLECTION_NAME=rh_rag_docs_bge_m3
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
RAG_MIN_SCORE=0.25
RAG_MAX_CONTEXT_CHARS=2200
RAG_MAX_CHARS_PER_DOC=850
RAG_SOURCE_FOCUS_MARGIN=0.08
REINDEX_CLEAN=false

# =============================================================================
# Comportamiento del webhook
# =============================================================================
# true (default) = procesamiento asíncrono vía Celery (recomendado producción)
# false = síncrono en el mismo request (solo diagnóstico)
INBOUND_DEBOUNCE_ENABLED=true
INBOUND_DEBOUNCE_SECONDS=6
INBOUND_DEBOUNCE_TTL_SECONDS=900
WEBHOOK_RATE_LIMIT_ENABLED=true
WEBHOOK_RATE_LIMIT_MAX_PER_MINUTE=30

# =============================================================================
# Telemetría / debug
# =============================================================================
INCLUDE_ERROR_DETAILS=false
CHROMA_ANONYMIZED_TELEMETRY=false
ANONYMIZED_TELEMETRY=false
POSTHOG_DISABLED=true
