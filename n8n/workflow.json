    {
      "parameters": {
        "jsCode": "const input = $input.all();\n\nconst messages = input\n  .map(item => item.json)\n  .filter(m => m.role && m.message)\n  .sort((a, b) => new Date(a.created_at) - new Date(b.created_at));\n\nconst history = messages.length > 0\n  ? messages\n      .map(m => {\n        const role = m.role === 'assistant' ? 'Agente' : 'Candidato';\n        return `${role}: ${m.message}`;\n      })\n      .join('\\n')\n  : 'No hay historial previo.';\n\nconst setData = $node[\"Set extract\"].json;\n\nreturn [\n  {\n    json: {\n      chat_id: setData.chat_id,\n      chat_type: setData.chat_type,\n      username: setData.username,\n      first_name: setData.first_name,\n      text: setData.text,\n      message_id: setData.message_id,\n      conversation_key: setData.conversation_key,\n      history\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
