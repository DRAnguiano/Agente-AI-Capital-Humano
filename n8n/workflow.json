        "query": "WITH payload AS (\n    SELECT $1::jsonb AS j\n)\nINSERT INTO rh_messages (\n    conversation_key,\n    role,\n    message\n)\nSELECT\n    j->>'conversation_key',\n    'assistant',\n    j->>'text'\nFROM payload\nRETURNING id;",
