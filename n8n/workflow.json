    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH payload AS (\n    SELECT $1::jsonb AS j\n)\nINSERT INTO rh_conversations (\n    channel,\n    channel_user_id,\n    conversation_key,\n    current_stage\n)\nSELECT\n    'telegram',\n    j->>'chat_id',\n    j->>'conversation_key',\n    'START'\nFROM payload\nON CONFLICT (conversation_key)\nDO UPDATE SET\n    updated_at = now()\nRETURNING\n    id,\n    channel,\n    channel_user_id,\n    conversation_key,\n    current_stage,\n    status;",
        "options": {
          "queryReplacement": "=={{JSON.stringify({\n  chat_id: $node[\"Set extract\"].json.chat_id,\n  conversation_key: $node[\"Set extract\"].json.conversation_key\n})}}"
        }
